modules = ["python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "postgresql", "rustc", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
APP_NAME = "منصة جمال عبد الناصر"
APP_URL = "http://localhost:5000"
ENVIRONMENT = "development"
DEBUG = "true"
ADMIN_EMAIL = "admin@example.com"
ADMIN_PASSWORD = "ChangeMe!2026"
JWT_ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = "120"
SITE_AUTHOR = "جمال عبد الناصر"
SITE_DESCRIPTION = "منصة شخصية احترافية للمشاريع والخدمات والمنتجات الرقمية والمقالات"
SITE_LOCALE = "ar_SA"
DEFAULT_OG_IMAGE = "/static/images/og-default.jpg"
GOOGLE_INDEXING_KEY_FILE = ""
GOOGLE_SEARCH_CONSOLE_SITE = ""
UPLOAD_DIR = "uploads"
MAX_UPLOAD_MB = "50"
SECRET_KEY = "dev-secret-replit-change-me-in-production-32chars"
REDIS_URL = "redis://localhost:6379/0"
SUPABASE_BUCKET = "uploads"
SUPABASE_JWKS_URL = "https://bmaqlynnbhbnrsbuboim.supabase.co/auth/v1/.well-known/jwks.json"
SUPABASE_PUBLISHABLE_KEY = "sb_publishable_2oxXLQ5MKkWhgG1XlBOXdQ_Swub8v85"
SUPABASE_URL = "https://bmaqlynnbhbnrsbuboim.supabase.co"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--worker-class=uvicorn.workers.UvicornWorker", "-w", "2", "app.main:app"]
