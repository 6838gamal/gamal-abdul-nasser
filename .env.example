# ================================================================
#  ملف البيئة - انسخ هذا الملف إلى .env وعدّل القيم
#  cp .env.example .env
# ================================================================

# ─── التطبيق الأساسي ─────────────────────────────────────────────
APP_NAME="منصة جمال عبد الناصر"
APP_URL=https://yourdomain.com
# أنشئ مفتاحاً عشوائياً آمناً: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ENVIRONMENT=production
DEBUG=false

# ─── قاعدة البيانات ──────────────────────────────────────────────
# للاستخدام مع Docker Compose (الافتراضي):
DATABASE_URL=postgresql://postgres:postgres@db:5432/gan_platform
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/gan_platform

# للاستخدام مع قاعدة بيانات خارجية (Render / Supabase / Neon / Railway):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
#   SYNC_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
#
# داخل Replit يمكن استخدام هذا المتغير بدلاً من DATABASE_URL:
#   RENDER_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=disable

# ─── Redis (اختياري - لتحديد معدل الطلبات في الإنتاج) ──────────────
REDIS_URL=redis://redis:6379/0

# ─── حساب المدير (يُنشأ تلقائياً عند أول تشغيل) ─────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!2026

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

# ─── معلومات الموقع الافتراضية ───────────────────────────────────
SITE_AUTHOR="جمال عبد الناصر"
SITE_DESCRIPTION="منصة شخصية احترافية للمشاريع والخدمات والمنتجات الرقمية والمقالات"
SITE_LOCALE=ar_SA
DEFAULT_OG_IMAGE=/static/images/og-default.jpg

# ─── Google Indexing API (اختياري) ───────────────────────────────
# احصل على service account key من Google Search Console
GOOGLE_INDEXING_KEY_FILE=
GOOGLE_SEARCH_CONSOLE_SITE=

# ─── رفع الملفات ─────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50
